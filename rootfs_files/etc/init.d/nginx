#!/bin/sh

### BEGIN INIT INFO
# Provides:          nginx
# Required-Start:    $local_fs $remote_fs $network $syslog $named
# Required-Stop:     $local_fs $remote_fs $network $syslog $named
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: starts the nginx web server
# Description:       starts nginx using start-stop-daemon
### END INIT INFO

PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
DAEMON=/usr/sbin/nginx
NAME=nginx
DESC=nginx

# Include nginx defaults if available
if [ -r /etc/default/nginx ]; then
  . /etc/default/nginx
fi

STOP_SCHEDULE="${STOP_SCHEDULE:-QUIT/5/TERM/5/KILL/5}"

test -x $DAEMON || exit 0

. /lib/init/vars.sh
. /lib/lsb/init-functions

# Import MOS functions
. /usr/local/lib/functions/mos-common

# Try to extract nginx pidfile
PID=$(cat /etc/nginx/nginx.conf | grep -Ev '^\s*#' | awk 'BEGIN { RS="[;{}]" } { if ($1 == "pid") print $2 }' | head -n1)
if [ -z "$PID" ]; then
  PID=/run/nginx.pid
fi

if [ -n "$ULIMIT" ]; then
  # Set ulimit if it is set in /etc/default/nginx
  ulimit $ULIMIT
fi

# MOS custom: update Frontend
mos_update_frontend() {
  # Set curl Header
  GH_TOKEN=$(jq -r '.github // empty' /boot/config/system/tokens.json)
  if [ ! -z "$GH_TOKEN" ] ; then
    TOKEN="$(decrypt_password "$GH_TOKEN" "tokens")"
    HEADER=(--header "Authorization: Bearer $TOKEN")
  else
    HEADER=()
  fi

  # Get Asset ID
  FRONTEND_JSON=$(curl -s --request GET \
    --url "https://api.github.com/repos/ich777/mos-frontend/releases/latest" \
    "${HEADER[@]}" \
    --header "X-GitHub-Api-Version: 2022-11-28")
  FRONTEND_V=$(echo $FRONTEND_JSON | jq -r '.tag_name')
  FRONTEND_ASSET_ID=$(echo $FRONTEND_JSON | jq -r '.assets[] | select(.name | startswith("mos-frontend") and endswith(".tar.gz")) | .id')

  # Remove WebUI
  rm -rf /var/www/assets /var/www/index.html 2>/dev/null
  find /var/www -maxdepth 1 -type f -name "mos*" -delete

  # Download and extract new WebUI
  curl --progress-bar -L \
    "${HEADER[@]}" \
    --header "Accept: application/octet-stream" \
    --header "X-GitHub-Api-Version: 2022-11-28" \
    --output "/tmp/frontend.tar.gz" \
    "https://api.github.com/repos/ich777/mos-frontend/releases/assets/$FRONTEND_ASSET_ID"
  tar -C /var/www/ -xf /tmp/frontend.tar.gz
  rm -rf /tmp/frontend.tar.gz

  jq --arg frontend_v "${FRONTEND_V}_updated" '.mos.frontend = $frontend_v' /etc/mos-release.json > /etc/mos-release.json.tmp && mv /etc/mos-release.json.tmp /etc/mos-release.json
}

start_nginx() {
  # Start the daemon/service
  #
  # Returns:
  #   0 if daemon has been started
  #   1 if daemon was already running
  #   2 if daemon could not be started

  mkdir -p /var/log/nginx /var/www/mos-plugins >/dev/null 2>&1

  # Get Ports and Interfaces
  SYSTEM_JSON="$(cat /boot/config/system.json)"
  FRONTEND_HTTP_PORT=$(echo "$SYSTEM_JSON" | jq -r '.webui.ports.http // 80')
  INTERFACES=$(echo "$SYSTEM_JSON" | jq -r '.webui.listen_interfaces[]? // empty')

  # Construct listen block
  if [ -z "$INTERFACES" ] ; then
    LISTEN_BLOCK="  listen                  ${FRONTEND_HTTP_PORT};"
  else
    LISTEN_BLOCK=""
    for interface in $INTERFACES ; do
      IP=$(ip addr show "$interface" 2>/dev/null | grep 'inet ' | awk '{print $2}' | cut -d/ -f1)
      [ -z "$IP" ] && continue
      LISTEN_BLOCK="${LISTEN_BLOCK}  listen                  ${IP}:${FRONTEND_HTTP_PORT};\n"
    done
    if [ -z "$LISTEN_BLOCK" ] ; then
      LISTEN_BLOCK="  listen                  ${FRONTEND_HTTP_PORT};"
    fi
  fi

  # Remove all listen lines between # MOSHTTPPORT and # ENDENDMOSHTTPPORT
  sed -i '/# MOSHTTPPORT/,/# ENDMOSHTTPPORT/{/^\s*listen/d}' /etc/nginx/nginx.conf

  # Inject new LISTEN_BLOCK after # MOSHTTPPORT
  sed -i "/# MOSHTTPPORT/a\\
  $(echo -e "$LISTEN_BLOCK" | sed '/^$/d')" /etc/nginx/nginx.conf

  start-stop-daemon --start --quiet --pidfile $PID --exec $DAEMON --test > /dev/null || return 1
  start-stop-daemon --start --quiet --pidfile $PID --exec $DAEMON -- \
    $DAEMON_OPTS 2>/dev/null || return 2

  # MOS Custom: bind mount os_icons directory
  [ ! -d /var/www/os_icons ] && \
    mkdir -p /var/www/os_icons

  mount --bind /var/lib/os_icons /var/www/os_icons 2>/dev/null
  chmod -R 777 /var/lib/os_icons
}

test_config() {
  # Test the nginx configuration
  $DAEMON -t $DAEMON_OPTS >/dev/null 2>&1
}

stop_nginx() {
  # Stops the daemon/service
  #
  # Return
  #   0 if daemon has been stopped
  #   1 if daemon was already stopped
  #   2 if daemon could not be stopped
  #   other if a failure occurred
  start-stop-daemon --stop --quiet --retry=$STOP_SCHEDULE --pidfile $PID --name $NAME
  RETVAL="$?"
  # MOS Custom: umount os_icons directory
  umount -f /var/www/os_icons 2>/dev/null
  sleep 1
  return "$RETVAL"
}

reload_nginx() {
  # Function that sends a SIGHUP to the daemon/service
  start-stop-daemon --stop --signal HUP --quiet --pidfile $PID --name $NAME
  return 0
}

rotate_logs() {
  # Rotate log files
  start-stop-daemon --stop --signal USR1 --quiet --pidfile $PID --name $NAME
  return 0
}

upgrade_nginx() {
  # Online upgrade nginx executable
  # http://nginx.org/en/docs/control.html
  #
  # Return
  #   0 if nginx has been successfully upgraded
  #   1 if nginx is not running
  #   2 if the pid files were not created on time
  #   3 if the old master could not be killed
  if start-stop-daemon --stop --signal USR2 --quiet --pidfile $PID --name $NAME; then
    # Wait for both old and new master to write their pid file
    while [ ! -s "${PID}.oldbin" ] || [ ! -s "${PID}" ]; do
      cnt=`expr $cnt + 1`
      if [ $cnt -gt 10 ]; then
        return 2
      fi
      sleep 1
    done
    # Everything is ready, gracefully stop the old master
    if start-stop-daemon --stop --signal QUIT --quiet --pidfile "${PID}.oldbin" --name $NAME; then
      return 0
    else
      return 3
    fi
  else
    return 1
  fi
}

case "$1" in
  start)
    log_daemon_msg "Starting $DESC" "$NAME"
    start_nginx
    case "$?" in
      0|1) log_end_msg 0 ;;
      2)   log_end_msg 1 ;;
    esac
  ;;
  stop)
    log_daemon_msg "Stopping $DESC" "$NAME"
    stop_nginx
    case "$?" in
      0|1) log_end_msg 0 ;;
      2)   log_end_msg 1 ;;
    esac
  ;;
  restart)
    log_daemon_msg "Restarting $DESC" "$NAME"

    # Check configuration before stopping nginx
    if ! test_config; then
      log_end_msg 1 # Configuration error
      exit $?
    fi

    stop_nginx
    case "$?" in
      0|1)
        start_nginx
        case "$?" in
          0) log_end_msg 0 ;;
          1) log_end_msg 1 ;; # Old process is still running
          *) log_end_msg 1 ;; # Failed to start
        esac
      ;;
      *)
        # Failed to stop
        log_end_msg 1
      ;;
    esac
  ;;
  reload|force-reload)
    log_daemon_msg "Reloading $DESC configuration" "$NAME"

    # Check configuration before stopping nginx
    #
    # This is not entirely correct since the on-disk nginx binary
    # may differ from the in-memory one, but that's not common.
    # We prefer to check the configuration and return an error
    # to the administrator.
    if ! test_config; then
      log_end_msg 1 # Configuration error
      exit $?
    fi

    reload_nginx
    log_end_msg $?
  ;;
  configtest|testconfig)
    log_daemon_msg "Testing $DESC configuration"
    test_config
    log_end_msg $?
  ;;
  status)
    status_of_proc -p $PID "$DAEMON" "$NAME" && exit 0 || exit $?
  ;;
  upgrade)
    log_daemon_msg "Upgrading binary" "$NAME"
    upgrade_nginx
    log_end_msg $?
  ;;
  update)
    log_daemon_msg "Updating mos-frontend" "$NAME"

    # Check configuration before stopping nginx
    if ! test_config; then
      log_end_msg 1 # Configuration error
      exit $?
    fi

    stop_nginx
    case "$?" in
      0|1)
        mos_update_frontend
        start_nginx
        case "$?" in
          0) log_end_msg 0 ;;
          1) log_end_msg 1 ;; # Old process is still running
          *) log_end_msg 1 ;; # Failed to start
        esac
      ;;
      *)
        # Failed to stop
        log_end_msg 1
      ;;
    esac
  ;;
  rotate)
    log_daemon_msg "Re-opening $DESC log files" "$NAME"
    rotate_logs
    log_end_msg $?
  ;;
  *)
    echo "Usage: $NAME {start|stop|restart|update|reload|force-reload|status|configtest|rotate|upgrade}" >&2
    exit 3
  ;;
esac
