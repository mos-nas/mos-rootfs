#!/bin/sh
### BEGIN INIT INFO
# Provides:          networking ifupdown
# Required-Start:    mountkernfs $local_fs urandom
# Required-Stop:     $local_fs
# Default-Start:     S
# Default-Stop:      0 6
# Short-Description: Raise network interfaces.
# Description:       Prepare /run/network directory, ifstate file and raise network interfaces, or take them down.
### END INIT INFO

PATH="/sbin:/bin:/usr/sbin:/usr/bin"
RUN_DIR="/run/network"
IFSTATE="$RUN_DIR/ifstate"
STATEDIR="$RUN_DIR/state"

[ -x "$(command -v ifup)" ] || exit 0
[ -x "$(command -v ifdown)" ] || exit 0

. /lib/lsb/init-functions

CONFIGURE_INTERFACES=yes
EXCLUDE_INTERFACES=
VERBOSE=no

[ -f /etc/default/networking ] && . /etc/default/networking

verbose=""
[ "$VERBOSE" = yes ] && verbose=-v

process_exclusions() {
  set -- $EXCLUDE_INTERFACES
  exclusions=""
  for d
  do
    exclusions="-X $d $exclusions"
  done
  echo $exclusions
}

process_options() {
  [ -e /etc/network/options ] || return 0
  log_warning_msg "/etc/network/options still exists and it will be IGNORED! Please use /etc/sysctl.conf instead."
}

check_ifstate() {
  if [ ! -d "$RUN_DIR" ] ; then
    if ! mkdir -p "$RUN_DIR" ; then
      log_failure_msg "can't create $RUN_DIR"
      exit 1
    fi
    if ! chown root:netdev "$RUN_DIR" ; then
      log_warning_msg "can't chown $RUN_DIR"
    fi
  fi
  if [ ! -r "$IFSTATE" ] ; then
    if ! :> "$IFSTATE" ; then
      log_failure_msg "can't initialise $IFSTATE"
      exit 1
    fi
  fi
}

check_network_file_systems() {
  [ -e /proc/mounts ] || return 0

  if [ -e /etc/iscsi/iscsi.initramfs ] ; then
    log_warning_msg "not deconfiguring network interfaces: iSCSI root is mounted."
    exit 0
  fi

  while read DEV MTPT FSTYPE REST ; do
    case $DEV in
      /dev/nbd*|/dev/nd[a-z]*|/dev/etherd/e*|curlftpfs*)
        log_warning_msg "not deconfiguring network interfaces: network devices still mounted."
        exit 0
      ;;
    esac
    case $FSTYPE in
      nfs|nfs4|smbfs|ncp|ncpfs|cifs|coda|ocfs2|gfs|pvfs|pvfs2|fuse.httpfs|fuse.curlftpfs)
        log_warning_msg "not deconfiguring network interfaces: network file systems still mounted."
        exit 0
      ;;
    esac
  done < /proc/mounts
}

check_network_swap() {
  [ -e /proc/swaps ] || return 0

  while read DEV MTPT FSTYPE REST ; do
    case $DEV in
      /dev/nbd*|/dev/nd[a-z]*|/dev/etherd/e*)
        log_warning_msg "not deconfiguring network interfaces: network swap still mounted."
        exit 0
      ;;
    esac
  done < /proc/swaps
}

ifup_hotplug () {
  if [ -d /sys/class/net ] ; then
    ifaces=$(for iface in $(ifquery --list --allow=hotplug)
      do
        link=${iface%%:*}
        link=${link%%.*}
        if [ -e "/sys/class/net/$link" ] && ! ifquery --state "$iface" >/dev/null ; then
          echo "$iface"
        fi
      done)
    if [ -n "$ifaces" ] ; then
      ifup $ifaces "$@" || true
    fi
  fi
}

# MOS custom: Bring up interfaces with parallel DHCP
ifup_parallel() {
  DHCP_IFACES=""
  [ -f "$DHCP_INTERFACES_FILE" ] && DHCP_IFACES=$(cat "$DHCP_INTERFACES_FILE")

  if [ -z "$DHCP_IFACES" ] ; then
    # No DHCP interfaces — standard bring-up
    ifup -a "$@"
    return $?
  fi

  # Build exclusion flags for DHCP interfaces
  dhcp_exclusions=""
  for iface in $DHCP_IFACES ; do
    dhcp_exclusions="$dhcp_exclusions -X $iface"
  done

  # Bring up non-DHCP interfaces (instant)
  ifup -a $dhcp_exclusions "$@" || true

  # Bring up DHCP interfaces in parallel (console output suppressed, dhclient logs to syslog)
  for iface in $DHCP_IFACES ; do
    ifup "$iface" "$@" > /dev/null 2>&1 &
  done
  wait

  # Cleanup
  rm -f "$DHCP_INTERFACES_FILE"
}

# MOS custom: Paths
NETWORK_JSON="/boot/config/network.json"
MOS_RUN_DIR="/var/mos"
DHCP_INTERFACES_FILE="$MOS_RUN_DIR/dhcp_interfaces"

# MOS custom: Disable IPv6 globally
disable_ipv6() {
  sysctl -wq net.ipv6.conf.all.disable_ipv6=1
  sysctl -wq net.ipv6.conf.default.disable_ipv6=1
  sysctl -wq net.ipv6.conf.lo.disable_ipv6=1
  sysctl -wq net.ipv6.conf.all.forwarding=0
}

# MOS custom: Enable IPv6 globally
enable_ipv6() {
  sysctl -wq net.ipv6.conf.all.disable_ipv6=0
  sysctl -wq net.ipv6.conf.default.disable_ipv6=0
  sysctl -wq net.ipv6.conf.lo.disable_ipv6=0
  sysctl -wq net.ipv6.conf.all.forwarding=1
  sysctl -wq net.ipv6.conf.all.accept_ra=2
  sysctl -wq net.ipv6.conf.default.accept_ra=2
}

# MOS custom: Append a line to the interfaces config buffer
interface_config() {
  if [ -z "$INTERFACE_CFG" ] ; then
    INTERFACE_CFG="$1"
  else
    INTERFACE_CFG="${INTERFACE_CFG}"'\n'"$1"
  fi
}

# MOS custom: Create bridge interface (idempotent — removes and recreates if exists)
bridge_setup() {
  if ip link show "$1" > /dev/null 2>&1 ; then
    ip link set "$1" down 2>/dev/null || true
    brctl delbr "$1" 2>/dev/null || true
  fi
  brctl addbr "$1"
}

# MOS custom: Add member interfaces to bridge (ensures interfaces are down first)
bridge_add_interface() {
  for interface in $2 ; do
    ip link set "$interface" down 2>/dev/null || true
    brctl addif "$1" "$interface" 2>/dev/null || true
    if [ -z "$INTERFACE_ADDITIONAL" ] ; then
      INTERFACE_ADDITIONAL="auto $interface\niface $interface inet manual\n"
    else
      INTERFACE_ADDITIONAL="${INTERFACE_ADDITIONAL}"'\n'"auto $interface\niface $interface inet manual\n"
    fi
  done
}

# MOS custom: Detect all physical network interfaces
detect_interfaces() {
  DETECTED="["
  FIRST=true
  VIRTUAL_PREFIXES="lo veth docker br- virbr tailscale wt bond dummy tunl sit vxlan flannel cni lxc"

  for IFACE_PATH in /sys/class/net/* ; do
    IFACE_NAME=$(basename "$IFACE_PATH")

    # Skip virtual interface prefixes
    SKIP=false
    for PREFIX in $VIRTUAL_PREFIXES ; do
      case "$IFACE_NAME" in
        ${PREFIX}*)
          SKIP=true
          break
        ;;
      esac
    done
    [ "$SKIP" = "true" ] && continue

    # Check if physical device (has /device symlink)
    if [ ! -e "$IFACE_PATH/device" ] ; then
      # Fallback: check type (1 = Ethernet)
      [ -f "$IFACE_PATH/type" ] || continue
      IFACE_TYPE=$(cat "$IFACE_PATH/type" 2>/dev/null)
      [ "$IFACE_TYPE" = "1" ] || continue
    fi

    # Read MAC address
    [ -f "$IFACE_PATH/address" ] || continue
    IFACE_MAC=$(cat "$IFACE_PATH/address" 2>/dev/null | tr '[:upper:]' '[:lower:]')
    [ -z "$IFACE_MAC" ] && continue
    [ "$IFACE_MAC" = "00:00:00:00:00:00" ] && continue

    if [ "$FIRST" = "true" ] ; then
      FIRST=false
    else
      DETECTED="${DETECTED},"
    fi
    DETECTED="${DETECTED}{\"name\":\"${IFACE_NAME}\",\"mac\":\"${IFACE_MAC}\"}"
  done

  DETECTED="${DETECTED}]"
  echo "$DETECTED"
}

# MOS custom: Reconcile detected interfaces with network.json config
# Matches by MAC address, updates kernel names, marks orphans, adds new interfaces
reconcile_interfaces() {
  [ -f "$NETWORK_JSON" ] || return 0

  DETECTED_JSON=$(detect_interfaces)
  DETECTED_COUNT=$(echo "$DETECTED_JSON" | jq 'length')
  [ "$DETECTED_COUNT" -eq 0 ] && return 0

  CHANGED=false

  # Legacy entries (no mac field) — assign MAC by kernel name
  IFACE_COUNT=$(jq '.interfaces | length' "$NETWORK_JSON")
  IDX=0
  while [ "$IDX" -lt "$IFACE_COUNT" ] ; do
    IFACE_MAC=$(jq -r ".interfaces[$IDX].mac // empty" "$NETWORK_JSON")
    IFACE_TYPE=$(jq -r ".interfaces[$IDX].type" "$NETWORK_JSON")
    IFACE_NAME=$(jq -r ".interfaces[$IDX].name" "$NETWORK_JSON")

    if [ -z "$IFACE_MAC" ] && [ "$IFACE_TYPE" != "bridge" ] && [ "$IFACE_TYPE" != "bond" ] ; then
      # Find detected interface by name
      FOUND_MAC=$(echo "$DETECTED_JSON" | jq -r --arg n "$IFACE_NAME" '.[] | select(.name==$n) | .mac')
      if [ -n "$FOUND_MAC" ] ; then
        # Assign MAC to legacy entry
        jq --argjson idx "$IDX" --arg mac "$FOUND_MAC" '.interfaces[$idx].mac = $mac' "$NETWORK_JSON" > "${NETWORK_JSON}.tmp" && mv "${NETWORK_JSON}.tmp" "$NETWORK_JSON"
        CHANGED=true
        logger -t networking "Assigned MAC $FOUND_MAC to $IFACE_NAME"
      fi
    fi
    IDX=$((IDX + 1))
  done

  # Match configured interfaces against detected by MAC Address
  IFACE_COUNT=$(jq '.interfaces | length' "$NETWORK_JSON")
  CONFIGURED_MACS=""
  IDX=0
  while [ "$IDX" -lt "$IFACE_COUNT" ] ; do
    IFACE_MAC=$(jq -r ".interfaces[$IDX].mac // empty" "$NETWORK_JSON")
    IFACE_TYPE=$(jq -r ".interfaces[$IDX].type" "$NETWORK_JSON")
    IFACE_NAME=$(jq -r ".interfaces[$IDX].name" "$NETWORK_JSON")
    IFACE_STATUS=$(jq -r ".interfaces[$IDX].status // \"enabled\"" "$NETWORK_JSON")

    if [ "$IFACE_TYPE" = "bridge" ] || [ "$IFACE_TYPE" = "bond" ] ; then
      IDX=$((IDX + 1))
      continue
    fi

    if [ -n "$IFACE_MAC" ] ; then
      CONFIGURED_MACS="${CONFIGURED_MACS} ${IFACE_MAC}"

      # Check if MAC exists in detected interfaces
      DETECTED_NAME=$(echo "$DETECTED_JSON" | jq -r --arg m "$IFACE_MAC" '.[] | select(.mac==$m) | .name')

      if [ -n "$DETECTED_NAME" ] ; then
        # MAC Address found update kernel name if changed
        if [ "$IFACE_NAME" != "$DETECTED_NAME" ] ; then
          jq --argjson idx "$IDX" --arg name "$DETECTED_NAME" '.interfaces[$idx].name = $name' "$NETWORK_JSON" > "${NETWORK_JSON}.tmp" && mv "${NETWORK_JSON}.tmp" "$NETWORK_JSON"
          CHANGED=true
          logger -t networking "Updated $IFACE_MAC: $IFACE_NAME -> $DETECTED_NAME"
        fi
        # Ensure status is enabled
        if [ "$IFACE_STATUS" = "orphan" ] ; then
          jq --argjson idx "$IDX" '.interfaces[$idx].status = "enabled"' "$NETWORK_JSON" > "${NETWORK_JSON}.tmp" && mv "${NETWORK_JSON}.tmp" "$NETWORK_JSON"
          CHANGED=true
          logger -t networking "Reactivated $IFACE_MAC ($DETECTED_NAME)"
        fi
      else
        # MAC Adress not in system mark as orphan
        if [ "$IFACE_STATUS" != "orphan" ] && [ "$IFACE_STATUS" != "disabled" ] ; then
          jq --argjson idx "$IDX" '.interfaces[$idx].status = "orphan"' "$NETWORK_JSON" > "${NETWORK_JSON}.tmp" && mv "${NETWORK_JSON}.tmp" "$NETWORK_JSON"
          CHANGED=true
          logger -t networking "Orphaned $IFACE_NAME ($IFACE_MAC)"
        fi
      fi
    fi
    IDX=$((IDX + 1))
  done

  # Add newly detected interfaces not in config
  DIDX=0
  while [ "$DIDX" -lt "$DETECTED_COUNT" ] ; do
    DET_MAC=$(echo "$DETECTED_JSON" | jq -r ".[$DIDX].mac")
    DET_NAME=$(echo "$DETECTED_JSON" | jq -r ".[$DIDX].name")

    IS_CONFIGURED=false
    for CMAC in $CONFIGURED_MACS ; do
      if [ "$CMAC" = "$DET_MAC" ] ; then
        IS_CONFIGURED=true
        break
      fi
    done

    if [ "$IS_CONFIGURED" = "false" ] ; then
      # Add new interface with DHCP
      NEW_IFACE="{\"mac\":\"${DET_MAC}\",\"name\":\"${DET_NAME}\",\"label\":null,\"type\":\"ethernet\",\"mode\":null,\"interfaces\":[],\"ipv4\":[{\"dhcp\":true}],\"ipv6\":[],\"vlans\":[],\"mtu\":null,\"hw_addr\":null,\"status\":\"enabled\"}"
      jq --argjson iface "$NEW_IFACE" '.interfaces += [$iface]' "$NETWORK_JSON" > "${NETWORK_JSON}.tmp" && mv "${NETWORK_JSON}.tmp" "$NETWORK_JSON"
      CHANGED=true
      logger -t networking "Added new interface $DET_NAME ($DET_MAC)"
    fi
    DIDX=$((DIDX + 1))
  done

  [ "$CHANGED" = "true" ] && log_progress_msg "interfaces reconciled"
}

# MOS custom: Generate /etc/network/interfaces from network.json
configure_interfaces() {
  [ -f "$NETWORK_JSON" ] || return 0

  INTERFACES_JSON=$(jq '.interfaces' "$NETWORK_JSON")
  INTERFACE_CFG=""
  INTERFACE_ADDITIONAL=""
  DHCP_INTERFACES=""

  # Cleanup: tear down existing MOS-managed bridges and bonds before reconfiguring
  for BR in $(ls /sys/class/net/*/bridge/bridge_id 2>/dev/null | cut -d/ -f5) ; do
    case "$BR" in
      docker*|virbr*|lxcbr*) continue ;;  # skip non-MOS bridges
    esac
    ip link set "$BR" down 2>/dev/null || true
    brctl delbr "$BR" 2>/dev/null || true
  done
  if [ -f /sys/class/net/bonding_masters ] ; then
    for BOND in $(cat /sys/class/net/bonding_masters 2>/dev/null) ; do
      ip link set "$BOND" down 2>/dev/null || true
      echo "-$BOND" > /sys/class/net/bonding_masters 2>/dev/null || true
    done
  fi

  # Enable IPv4 forwarding
  sysctl -wq net.ipv4.ip_forward=1

  # Enable or Disable IPv6 globally
  IPV6=$(echo "$INTERFACES_JSON" | jq -r 'map(select((.type != "bridged") and (.ipv6 | length > 0))) | length > 0')
  if [ "${IPV6}" = "false" ] ; then
    disable_ipv6
  else
    enable_ipv6
  fi

  IFACE_COUNT=$(echo "$INTERFACES_JSON" | jq 'length')
  IDX=0
  while [ "$IDX" -lt "$IFACE_COUNT" ] ; do
    INTERFACE_JSON=$(echo "$INTERFACES_JSON" | jq ".[$IDX]")
    INTERFACE=$(echo "$INTERFACE_JSON" | jq -r '.name')
    TYPE=$(echo "$INTERFACE_JSON" | jq -r '.type')
    STATUS=$(echo "$INTERFACE_JSON" | jq -r '.status // "enabled"')
    MTU=$(echo "$INTERFACE_JSON" | jq -r '.mtu // empty')
    HW_ADDR=$(echo "$INTERFACE_JSON" | jq -r '.hw_addr // empty')

    # Skip orphan and disabled interfaces
    if [ "$STATUS" = "orphan" ] || [ "$STATUS" = "disabled" ] ; then
      IDX=$((IDX + 1))
      continue
    fi

    # Skip bridged/bonded interfaces (they are configured by bridge/bond sections)
    if [ "$TYPE" = "bridged" ] || [ "$TYPE" = "bonded" ] ; then
      IDX=$((IDX + 1))
      continue
    fi

    IPV4_COUNT=$(echo "$INTERFACE_JSON" | jq '.ipv4 // [] | length')

    if [ "$IPV4_COUNT" -eq 0 ] ; then
      # No IP config — manual mode (e.g. for LXC passthrough)
      interface_config "auto $INTERFACE"
      interface_config "iface $INTERFACE inet manual"
    else
      DHCP=$(echo "$INTERFACE_JSON" | jq -r 'if .ipv4[0].dhcp == false then "false" else "true" end')
      if [ "$DHCP" != "false" ] ; then
        interface_config "auto $INTERFACE"
        interface_config "iface $INTERFACE inet dhcp"
        DHCP_INTERFACES="${DHCP_INTERFACES:+$DHCP_INTERFACES }$INTERFACE"
      else
        ADDRESS=$(echo "$INTERFACE_JSON" | jq -r '.ipv4[0].address // empty')
        GATEWAY=$(echo "$INTERFACE_JSON" | jq -r '.ipv4[0].gateway // empty')
        DNS=$(echo "$INTERFACE_JSON" | jq -r '.ipv4[0].dns // [] | join(" ")')
        interface_config "auto $INTERFACE"
        interface_config "iface $INTERFACE inet static"
        [ -n "$ADDRESS" ] && interface_config "    address $ADDRESS"
        [ -n "$GATEWAY" ] && interface_config "    gateway $GATEWAY"
        [ -n "$DNS" ] && interface_config "    dns-nameservers $DNS"
      fi
    fi

    # MTU
    [ -n "$MTU" ] && interface_config "    mtu $MTU"

    # MAC spoofing (hw_addr)
    [ -n "$HW_ADDR" ] && interface_config "    hwaddress ether $HW_ADDR"

    # Bridge configuration
    if [ "$TYPE" = "bridge" ] ; then
      bridge_setup "$INTERFACE"
      BRIDGE_INTERFACES=$(echo "$INTERFACE_JSON" | jq -r '.interfaces // [] | join(" ")')
      if [ -n "$BRIDGE_INTERFACES" ] ; then
        interface_config "    bridge_ports $BRIDGE_INTERFACES"
        bridge_add_interface "$INTERFACE" "$BRIDGE_INTERFACES"
      fi

      # VLAN filtering on bridge (for VLAN-aware bridge, e.g. LXC VLAN passthrough)
      VLAN_FILTERING=$(echo "$INTERFACE_JSON" | jq -r '.vlan_filtering // false')
      if [ "$VLAN_FILTERING" = "true" ] ; then
        interface_config "    bridge_vlan_aware yes"
        BRIDGE_VIDS=$(echo "$INTERFACE_JSON" | jq -r '.bridge_vids // [] | if length > 0 then map(tostring) | join(" ") else empty end')
        if [ -n "$BRIDGE_VIDS" ] ; then
          interface_config "    bridge_vids $BRIDGE_VIDS"
        else
          interface_config "    bridge_vids 2-4094"
        fi
        # Ensure VLAN filtering is enabled (fallback for ifupdown v1 which ignores bridge_vlan_aware)
        interface_config "    post-up ip link set $INTERFACE type bridge vlan_filtering 1 || true"
        # Add VLANs from bridged member interfaces as bridge port VIDs
        for MEMBER in $BRIDGE_INTERFACES ; do
          MEMBER_JSON=$(echo "$INTERFACES_JSON" | jq --arg name "$MEMBER" '.[] | select(.name == $name)')
          MEMBER_VLAN_COUNT=$(echo "$MEMBER_JSON" | jq '.vlans // [] | length')
          MIDX=0
          while [ "$MIDX" -lt "$MEMBER_VLAN_COUNT" ] ; do
            VID=$(echo "$MEMBER_JSON" | jq -r ".vlans[$MIDX].vlan_id")
            interface_config "    post-up bridge vlan add vid $VID dev $MEMBER || true"
            MIDX=$((MIDX + 1))
          done
        done
      fi
    fi

    # Bond configuration
    if [ "$TYPE" = "bond" ] ; then
      BOND_INTERFACES=$(echo "$INTERFACE_JSON" | jq -r '.interfaces // [] | join(" ")')
      BOND_MODE=$(echo "$INTERFACE_JSON" | jq -r '.mode // empty')
      [ -n "$BOND_INTERFACES" ] && interface_config "    bond-slaves $BOND_INTERFACES"
      [ -n "$BOND_MODE" ] && interface_config "    bond-mode $BOND_MODE"
      interface_config "    bond-miimon 100"

      # Add bond slave interfaces as manual
      for SLAVE in $BOND_INTERFACES ; do
        if [ -z "$INTERFACE_ADDITIONAL" ] ; then
          INTERFACE_ADDITIONAL="auto $SLAVE\niface $SLAVE inet manual\n    bond-master $INTERFACE\n"
        else
          INTERFACE_ADDITIONAL="${INTERFACE_ADDITIONAL}"'\n'"auto $SLAVE\niface $SLAVE inet manual\n    bond-master $INTERFACE\n"
        fi
      done
    fi

    interface_config ""

    # VLAN configuration
    VLAN_COUNT=$(echo "$INTERFACE_JSON" | jq '.vlans // [] | length')
    VIDX=0
    while [ "$VIDX" -lt "$VLAN_COUNT" ] ; do
      VLAN_JSON=$(echo "$INTERFACE_JSON" | jq ".vlans[$VIDX]")
      VLAN_ID=$(echo "$VLAN_JSON" | jq -r '.vlan_id')
      VLAN_MTU=$(echo "$VLAN_JSON" | jq -r '.mtu // empty')
      VLAN_IPV4_COUNT=$(echo "$VLAN_JSON" | jq '.ipv4 // [] | length')
      VLAN_IFACE="${INTERFACE}.${VLAN_ID}"

      if [ "$VLAN_IPV4_COUNT" -eq 0 ] ; then
        # No IP config — manual mode (e.g. for LXC passthrough)
        interface_config "auto $VLAN_IFACE"
        interface_config "iface $VLAN_IFACE inet manual"
      else
        VLAN_DHCP=$(echo "$VLAN_JSON" | jq -r 'if .ipv4[0].dhcp == false then "false" else "true" end')
        if [ "$VLAN_DHCP" != "false" ] ; then
          interface_config "auto $VLAN_IFACE"
          interface_config "iface $VLAN_IFACE inet dhcp"
          DHCP_INTERFACES="${DHCP_INTERFACES:+$DHCP_INTERFACES }$VLAN_IFACE"
        else
          VLAN_ADDRESS=$(echo "$VLAN_JSON" | jq -r '.ipv4[0].address // empty')
          VLAN_GATEWAY=$(echo "$VLAN_JSON" | jq -r '.ipv4[0].gateway // empty')
          VLAN_DNS=$(echo "$VLAN_JSON" | jq -r '.ipv4[0].dns // [] | join(" ")')
          interface_config "auto $VLAN_IFACE"
          interface_config "iface $VLAN_IFACE inet static"
          [ -n "$VLAN_ADDRESS" ] && interface_config "    address $VLAN_ADDRESS"
          [ -n "$VLAN_GATEWAY" ] && interface_config "    gateway $VLAN_GATEWAY"
          [ -n "$VLAN_DNS" ] && interface_config "    dns-nameservers $VLAN_DNS"
        fi
      fi

      interface_config "    vlan-raw-device $INTERFACE"
      [ -n "$VLAN_MTU" ] && interface_config "    mtu $VLAN_MTU"
      interface_config ""

      VIDX=$((VIDX + 1))
    done

    IDX=$((IDX + 1))
  done
  echo -e "$INTERFACE_ADDITIONAL$INTERFACE_CFG" > /etc/network/interfaces

  # Save DHCP interface list for parallel bring-up
  mkdir -p "$MOS_RUN_DIR"
  echo "$DHCP_INTERFACES" > "$DHCP_INTERFACES_FILE"
}

case "$1" in
  start)
    # MOS custom:
    reconcile_interfaces
    configure_interfaces
    process_options
    check_ifstate

    if [ "$CONFIGURE_INTERFACES" = no ] ; then
      log_action_msg "Not configuring network interfaces, see /etc/default/networking"
      exit 0
    fi
    set -f
    exclusions=$(process_exclusions)
    log_action_begin_msg "Configuring network interfaces"
    if [ -x "$(command -v udevadm)" ] ; then
      if [ -n "$(ifquery --list --exclude=lo)" ] || [ -n "$(ifquery --list --allow=hotplug)" ] ; then
        udevadm settle || true
      fi
    fi
    if ifup_parallel $exclusions $verbose && ifup_hotplug $exclusions $verbose ; then
      log_action_end_msg $?
    else
      log_action_end_msg $?
    fi
  ;;

  stop)
    check_network_file_systems
    check_network_swap

    log_action_begin_msg "Deconfiguring network interfaces"
    if ifdown -a --exclude=lo $verbose ; then
      log_action_end_msg $?
    else
      log_action_end_msg $?
    fi
  ;;

  reload)
    process_options

    log_action_begin_msg "Reloading network interfaces configuration"
    state=$(ifquery --state)
    ifdown -a --exclude=lo $verbose || true

    # MOS custom:
    reconcile_interfaces
    configure_interfaces
    process_options
    check_ifstate

    if ifup_parallel --exclude=lo $verbose ; then
      log_action_end_msg $?
    else
      log_action_end_msg $?
    fi
  ;;

  force-reload|restart)
    process_options

    log_warning_msg "Manual network restart is not recommended. Please use the MOS WebUI to configure networking."
    log_action_begin_msg "Reconfiguring network interfaces"
    ifdown -a --exclude=lo $verbose || true

    # MOS custom:
    reconcile_interfaces
    configure_interfaces
    process_options
    check_ifstate

    set -f
    exclusions=$(process_exclusions)
    if ifup_parallel --exclude=lo $exclusions $verbose && ifup_hotplug $exclusions $verbose ; then
      log_action_end_msg $?
    else
      log_action_end_msg $?
    fi
  ;;

  *)
    echo "Usage: /etc/init.d/networking {start|stop|reload|restart|force-reload}"
    exit 1
  ;;
esac

exit 0
