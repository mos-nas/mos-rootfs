#!/bin/bash
# This script is part of MOS and will add NetBird to your
# Docker container if all requirements are met.

error_handler() {
  echo
  echo "ERROR: Container init failed!"
  echo "Putting container into sleep mode."
  echo "+----------------------------------------------------------"
  sleep infinity 2>/dev/null || while true; do sleep 3600; done
}

echo "+-[ MOS NetBird container init ]---------------------------"
echo

if [ -x "/usr/bin/with-contenv" ]; then
  echo "just-containers s6-overlay image found, importing variables..."
  ENV_VARS="$(/usr/bin/with-contenv bash -c 'env')"

  while IFS='=' read -r KEY VALUE; do
    export "${KEY}"="${VALUE}"
  done <<< "${ENV_VARS}"
fi

if [ ! -c /dev/net/tun ]; then
  echo "ERROR: Device /dev/net/tun not found!"
  echo "       Make sure to pass through /dev/net/tun to the container and add the"
  echo "       parameter --cap-add=NET_ADMIN to the Extra Parameters!"
  error_handler
fi

if [ ! -f /usr/bin/netbird ]; then
  echo "Detecting Package Manager..."
  if command -v apt-get >/dev/null 2>&1; then
    echo "Detected Advanced Package Tool!"
    PACKAGES_UPDATE="apt-get update"
    PACKAGES_INSTALL="apt-get -y install --no-install-recommends"
  elif command -v apk >/dev/null 2>&1; then
    echo "Detected Alpine Package Keeper!"
    PACKAGES_UPDATE="apk update"
    PACKAGES_INSTALL="apk add"
  else
    echo "ERROR: Detection failed!"
    error_handler
  fi

  echo "Installing dependencies..."
  echo "Please wait..."
  ${PACKAGES_UPDATE} >/dev/null 2>&1
  ${PACKAGES_INSTALL} jq wget ca-certificates iptables >/dev/null 2>&1
  echo "Done"

  if ! iptables -L >/dev/null 2>&1; then
    echo "ERROR: Cap: NET_ADMIN not available!"
    echo "       Make sure to add --cap-add=NET_ADMIN to the Extra Parameters"
    error_handler
  fi

  echo "NetBird not found, downloading..."
  echo "Please wait..."

  case "$(uname -m)" in
    x86_64)  NETBIRD_ARCH="amd64" ;;
    aarch64) NETBIRD_ARCH="arm64" ;;
    *)
      echo "ERROR: Unsupported architecture: $(uname -m)"
      error_handler
      ;;
  esac

  NETBIRD_VERSION=$(wget -qO- 'https://api.github.com/repos/netbirdio/netbird/releases/latest' | jq -r '.tag_name' | sed 's/^v//')

  if [ -z "${NETBIRD_VERSION}" ] || [ "${NETBIRD_VERSION}" == "null" ]; then
    echo "ERROR: Can't determine latest NetBird version"
    error_handler
  fi

  if [ ! -d /tmp/netbird ]; then
    mkdir -p /tmp/netbird
  fi

  if wget -q -nc --show-progress --progress=bar:force:noscroll -O /tmp/netbird/netbird.tgz "https://github.com/netbirdio/netbird/releases/download/v${NETBIRD_VERSION}/netbird_${NETBIRD_VERSION}_linux_${NETBIRD_ARCH}.tar.gz" ; then
    echo "Download from NetBird version ${NETBIRD_VERSION} successful!"
  else
    echo "ERROR: Download from NetBird version ${NETBIRD_VERSION} failed!"
    rm -rf /tmp/netbird
    error_handler
  fi

  tar -xf /tmp/netbird/netbird.tgz -C /usr/bin netbird
  chmod +x /usr/bin/netbird
  rm -rf /tmp/netbird

  echo "Done"

else
  echo "NetBird found, continuing..."
fi

unset NBD_PARAMS
unset NB_PARAMS

if [ ! -z "${NETBIRD_STATE_DIR}" ]; then
  NB_STATE_DIR="${NETBIRD_STATE_DIR}"
elif [ -v SERVER_DIR ]; then
  NB_STATE_DIR="${SERVER_DIR}/.netbird_state"
  echo "Setting NetBird state dir to: ${NB_STATE_DIR}"
elif [ -v DATA_DIR ]; then
  NB_STATE_DIR="${DATA_DIR}/.netbird_state"
  echo "Setting NetBird state dir to: ${NB_STATE_DIR}"
else
  NB_STATE_DIR="/config/.netbird_state"
  echo "Setting NetBird state dir to: ${NB_STATE_DIR}"
fi

if [ ! -d "${NB_STATE_DIR}" ]; then
  mkdir -p "${NB_STATE_DIR}"
fi

NB_CONFIG="${NB_STATE_DIR}/config.json"

if [ "${NETBIRD_USE_SSH}" == "true" ]; then
  echo "Enabling SSH server. See https://docs.netbird.io/get-started/cli"
  NB_PARAMS+=" --allow-server-ssh"
fi

if [ ! -z "${NETBIRD_MANAGEMENT_URL}" ]; then
  echo "Using management URL ${NETBIRD_MANAGEMENT_URL}"
  NB_PARAMS+=" --management-url=${NETBIRD_MANAGEMENT_URL}"
fi

if [ ! -z "${NETBIRD_HOSTNAME}" ]; then
  echo "Setting host name to ${NETBIRD_HOSTNAME}"
  NB_PARAMS+=" --hostname=${NETBIRD_HOSTNAME/ /}"
fi

if [ "${NETBIRD_LOG}" != "false" ]; then
  NBD_PARAMS+="--log-file console >>/var/log/netbird.log 2>&1 "
  NBD_MSG=" with log file /var/log/netbird.log"
else
  NBD_PARAMS+="--log-file console >/dev/null 2>&1 "
fi

if [[ ! -z "${NETBIRD_SETUP_KEY}" && -f "${NB_STATE_DIR}/.initialized" ]]; then
  echo
  echo "-> It is now safe to remove the variable NETBIRD_SETUP_KEY from your template <-"
  echo
  unset NETBIRD_SETUP_KEY
fi

if [ ! -z "${NETBIRD_SETUP_KEY}" ]; then
  NB_AUTH="--setup-key=${NETBIRD_SETUP_KEY} "
fi

if [ ! -z "${NETBIRD_SERVICE_PARAMS}" ]; then
  NBD_PARAMS="${NETBIRD_SERVICE_PARAMS} ${NBD_PARAMS}"
fi

if [ ! -z "${NETBIRD_PARAMS}" ]; then
  NB_PARAMS="${NETBIRD_PARAMS}${NB_PARAMS}"
fi

echo "Starting netbird daemon${NBD_MSG}"
eval netbird service run --config="${NB_CONFIG}" ${NBD_PARAMS}&

echo "Waiting for NetBird daemon..."
for _ in $(seq 1 30); do
  [ -S /var/run/netbird.sock ] && break
  sleep 1
done

if [ ! -S /var/run/netbird.sock ]; then
  echo "ERROR: NetBird daemon did not start in time!"
  if [ -f /var/log/netbird.log ]; then
    echo "Please check the logs:"
    tail -20 /var/log/netbird.log
  fi
  error_handler
fi

echo "Starting netbird"
eval netbird up ${NB_AUTH}${NB_PARAMS}
EXIT_STATUS="$?"

if [ "${EXIT_STATUS}" == "0" ]; then
  echo "Connecting to NetBird successful!"
  if [ ! -f "${NB_STATE_DIR}/.initialized" ]; then
    echo "Please don't remove this file!" > "${NB_STATE_DIR}/.initialized"
  fi
else
  echo "ERROR: Connecting to NetBird not successful!"
  if [ -f /var/log/netbird.log ]; then
    echo "Please check the logs:"
    tail -20 /var/log/netbird.log
  fi
  error_handler
fi

echo
echo "+----------------------------------------------------------"
